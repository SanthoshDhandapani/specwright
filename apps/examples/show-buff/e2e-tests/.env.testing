# E2E Testing Environment — managed by Specwright
BASE_URL=https://specwright-show-buff.vercel.app
TEST_ENV=
BASE_ENV=qat
NODE_ENV=test
HEADLESS=true
BROWSER=chromium
CHROME_ARGS="--no-sandbox,--disable-dev-shm-usage"
CUCUMBER_REPORT_PATH="reports/cucumber-bdd/report.json"
CODEGEN_OUTPUT_PATH="e2e-tests/playwright/generated"
TEST_TIMEOUT=120000
ENABLE_SCREENSHOTS=true
ENABLE_VIDEO_RECORDING=true
RETAIN_VIDEO_ON_SUCCESS=false
ENABLE_TRACING=false
AUTH_STRATEGY=oauth
# TEST_2FA_CODE=                          # 2FA OTP code (email-password + 2FA only; unused for oauth)
VITE_BUILD_ENVIRONMENT=testing
TEST_USER_EMAIL=san.itsnew@gmail.com
TEST_USER_NAME=Santhosh
TEST_USER_PICTURE=https://api.dicebear.com/9.x/initials/svg?seed=Santhosh
OAUTH_STORAGE_KEY=specwright-show-user
OAUTH_SIGNIN_PATH=/signin
OAUTH_BUTTON_TEST_ID=google-signin-button
PIPELINE_TICKET_ID=TEST-12180