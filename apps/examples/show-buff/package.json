{
  "name": "@specwright/show-buff",
  "version": "0.1.0",
  "private": true,
  "description": "ShowBuff — TV show discovery app, demo target for Specwright E2E test generation",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "bddgen": "npx bddgen",
    "test:bdd": "pnpm bddgen && playwright test --project setup --project serial-execution --project main-e2e",
    "test:bdd:all": "pnpm bddgen && playwright test",
    "test:bdd:auth": "pnpm bddgen && playwright test --project setup --project auth-tests",
    "test:bdd:serial": "pnpm bddgen && playwright test --project setup --project serial-execution",
    "test:bdd:debug": "pnpm bddgen && PWDEBUG=console playwright test --debug",
    "test:playwright": "playwright test",
    "test:playwright:headed": "playwright test --headed",
    "test:playwright:debug": "playwright test --debug",
    "report:playwright": "playwright show-report",
    "report:bdd": "node e2e-tests/scripts/generate-bdd-report.js",
    "report:bdd:open": "open reports/cucumber-bdd/html-report/index.html",
    "test:clean": "rm -rf reports .features-gen test-results e2e-tests/playwright/test-data/*.json"
  },
  "dependencies": {
    "@react-oauth/google": "^0.12.1",
    "jwt-decode": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.54.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "dotenv": "^17.2.0",
    "multiple-cucumber-html-reporter": "^3.10.0",
    "playwright-bdd": "^8.5.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.4.2"
  }
}
