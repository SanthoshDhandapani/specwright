{
  "name": "specwright",
  "version": "0.1.0",
  "private": false,
  "description": "AI-powered E2E test automation — Playwright BDD framework plugin + Electron desktop app + Claude Code agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/specwright/specwright.git"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "dist:mac": "pnpm --filter @specwright/desktop dist:mac",
    "dist:win": "pnpm --filter @specwright/desktop dist:win",
    "dist:linux": "pnpm --filter @specwright/desktop dist:linux",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "turbo": "^2.9.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.20.2",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.101",
    "@specwright/mcp": "workspace:*",
    "claude-runner": "^0.5.0"
  },
  "pnpm": {
    "overrides": {
      "jwt-decode>husky": "-"
    },
    "patchedDependencies": {},
    "neverBuiltDependencies": [
      "jwt-decode"
    ]
  }
}
