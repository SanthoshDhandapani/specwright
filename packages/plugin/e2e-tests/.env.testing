# Base Environment Configuration
BASE_ENV=qat
BASE_URL=http://localhost:5173
NODE_ENV=test

# Browser Configuration
HEADLESS=false
BROWSER=chromium
CHROME_ARGS="--no-sandbox,--disable-dev-shm-usage"

# Reports Configuration
CUCUMBER_REPORT_PATH="reports/cucumber-bdd/report.json"
CODEGEN_OUTPUT_PATH="e2e-tests/playwright/generated"

# Test Configuration
TEST_TIMEOUT=120000

# Visual Testing Configuration
ENABLE_SCREENSHOTS=true
ENABLE_VIDEO_RECORDING=true
RETAIN_VIDEO_ON_SUCCESS=false
ENABLE_TRACING=false

# Authentication Strategy
# Strategies: email-password | oauth | none
# - email-password: two-step login (email → password → optional 2FA)
# - oauth: click-based OAuth or mock sign-in button
# - none: skip authentication entirely
AUTH_STRATEGY=email-password

# Test Credentials (email-password and oauth strategies)
# TEST_USER_EMAIL=your-test-email@example.com
# TEST_USER_PASSWORD=your-test-password   # email-password only
# TEST_2FA_CODE=                          # 2FA OTP code (email-password + 2FA only; remove if unused)

# OAuth Strategy Configuration (only needed when AUTH_STRATEGY=oauth)
# OAUTH_STORAGE_KEY=your-localStorage-key  # preferred: bypasses OAuth popup
# OAUTH_SIGNIN_PATH=/signin                # path to sign-in page (default: /signin)
# OAUTH_BUTTON_TEST_ID=google-signin-button # fallback: click-based sign-in button
# OAUTH_POST_LOGIN_URL=**/                 # URL pattern after login (default: **/)

# Test User Identity (oauth strategy)
# TEST_USER_NAME=                          # display name (optional — derived from email if blank)
# TEST_USER_PICTURE=                       # avatar URL or data URI (optional — SVG initials auto-generated if blank)

# Build Environment
VITE_BUILD_ENVIRONMENT=testing
